	"about": {
		"title": "About",
		"subtitle": "A11yCert is a bilingual study platform for Korean learners preparing for IAAP CPACC and WAS certifications.",
		"purpose": {
			"title": "Purpose",
			"body": "Korean-language resources for IAAP accessibility certifications are scarce. A11yCert was created to bridge that gap — offering bilingual (Korean/English) study cards, flashcards, and practice quizzes so learners can prepare effectively for English-language exams."
		},
		"creator": {
			"title": "Creator",
			"name": "Isaac",
			"intro": "A developer passionate about web development and digital accessibility. This site was built while preparing for the CPACC exam, out of a need for quality Korean-language study materials.",
			"blogLabel": "Blog",
			"blogUrl": "https://www.codeslog.com"
		},
		"source": {
			"title": "Content Source",
			"body": "All study content is based on the official IAAP Body of Knowledge (BoK). Please refer to official IAAP materials alongside this site when preparing for your exam."
		},
		"disclaimer": {
			"title": "Disclaimer",
			"body": "This site is not affiliated with or endorsed by IAAP. It provides unofficial study materials. While we strive for accuracy, content may differ from actual exam questions. Please report errors via email at contact@a11ycert.com."
		}
	},
